// Artwish — Artist Commission Platform
// Schema v2: Service-centric dashboard refactor
// Chat & Notification models preserved as-is (already in production)

generator client {
  provider        = "prisma-client"
  output          = "../src/prisma/generated"
  moduleFormat    = "cjs"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

// ======================================
// ADMIN PANEL
// ======================================

model AdminUser {
  id           Int            @id @default(autoincrement())
  email        String         @unique
  passwordHash String
  name         String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AdminSession[]
  moderations  UserModeration[]

  @@map("admin_users")
}

model AdminSession {
  id        String    @id @default(cuid())
  adminId   Int
  admin     AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([adminId])
  @@map("admin_sessions")
}

// ======================================
// ENUMS
// ======================================

enum ModerationAction {
  BAN
  UNBAN
  SUSPEND
  UNSUSPEND
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LikesPrivacy {
  PUBLIC
  PRIVATE
}

enum MainPhaseKey {
  NEW
  PENDING
  READY
  WIP
}

// --- Service enums ---

enum ServiceStatus {
  DRAFT
  OPEN
  PAUSED
  CLOSED
}

enum ServiceRequestMode {
  MANUAL_REVIEW
  INSTANT_ORDER
}

enum ServiceQuestionType {
  SHORT_TEXT
  LONG_TEXT
  SINGLE_SELECT
  MULTI_SELECT
  BOOLEAN
  FILE
  NUMBER
}

// --- Order enums ---

enum OrderStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  WAITING_FOR_CLIENT
  DELIVERED
  COMPLETED
  CANCELLED
  REJECTED
}

enum OrderSource {
  SERVICE
  CUSTOM_REQUEST
}

// --- Payment enums ---

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  PAYPAL
}

enum PayoutStatus {
  PENDING
  SENT
  FRAUD
}

// --- Order event enums ---

enum OrderEventType {
  ORDER_CREATED
  ORDER_ACCEPTED
  ORDER_REJECTED
  PAYMENT_CAPTURED
  STATUS_CHANGED
  REVISION_REQUESTED
  ORDER_COMPLETED
  ORDER_CANCELLED
  MESSAGE_SENT
}

// --- Chat enums (preserved) ---

enum ConversationType {
  DIRECT
  GROUP
  ORDER
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
}

enum NotificationType {
  // Existing — used by chat/notification system
  NEW_MESSAGE
  NEW_FOLLOWER
  SHOWCASE_LIKE
  COMMISSION_UPDATE
  SYSTEM_ANNOUNCEMENT
  // New — for service/order features
  ORDER_CREATED
  ORDER_UPDATED
  SERVICE_PAUSED
  SERVICE_PUBLISHED
  ARTIST_VERIFIED
}

// ======================================
// USER CORE
// ======================================

model User {
  id              Int               @id @default(autoincrement())
  email           String            @unique
  passwordHash    String
  name            String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  role            String            @default("user")
  username        String            @unique
  subId           String            @unique
  verified        Boolean           @default(false)
  verifiedArtists Boolean           @default(false)
  avatar          String?           @default("avatars/default.jpg")
  banner          String?           @default("banners/default.jpg")
  bio             String?
  country         String?

  // Auth & Settings
  tokens          AuthToken?
  refreshTokens   RefreshToken[]
  socials         Socials?
  otps            otp[]
  settings        Settings?

  // Portfolio & Discovery
  showcases       Showcase?
  workflows       Workflow[]
  interactions    UserInteraction[]
  bookmarks       Bookmark[]
  profileSearches ProfileSearchRecord[] @relation("ProfileSearches")
  artistVerification ArtistVerificationRequest?

  // Services & Orders
  services            Service[]
  artistOrders        Order[]          @relation("ArtistOrders")
  clientOrders        Order[]          @relation("ClientOrders")
  orderEvents         OrderEvent[]     @relation("OrderEventActor")
  customRequestsMade  CustomRequest[]  @relation("CustomRequestClient")
  customRequestsRecv  CustomRequest[]  @relation("CustomRequestArtist")
  payouts             Payout[]         @relation("ArtistPayouts")

  // Social graph
  following       Follow[]          @relation("Following")
  followers       Follow[]          @relation("Followers")

  // Moderation
  isBanned        Boolean           @default(false)
  suspendedUntil  DateTime?
  banReason       String?
  moderations     UserModeration[]

  // Chat & Notifications
  conversations   ConversationParticipant[]
  sentMessages    Message[]
  notifications   Notification[]

  @@index([email])
  @@index([username])
}

model UserModeration {
  id        String           @id @default(cuid())
  userId    Int
  action    ModerationAction
  reason    String?
  duration  Int?
  expiresAt DateTime?
  adminId   Int
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin     AdminUser        @relation(fields: [adminId], references: [id])

  @@index([userId, createdAt])
  @@index([adminId])
  @@map("user_moderations")
}

// ======================================
// VERIFICATION / SETTINGS / SOCIALS / AUTH
// ======================================

model ArtistVerificationRequest {
  id                BigInt             @id @default(autoincrement())
  userId            Int                @unique
  status            VerificationStatus @default(PENDING)
  requestedAt       DateTime           @default(now())
  reviewedAt        DateTime?
  reviewReason      String?
  reviewedByAdminId Int?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, requestedAt])
  @@map("artist_verification_requests")
}

model Settings {
  id           Int          @id @default(autoincrement())
  userId       Int          @unique
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  likesPrivacy LikesPrivacy @default(PRIVATE)
  paypalEmail  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("settings")
}

model Socials {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  instagram String?
  twitter   String?
  facebook  String?
  tiktok    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model otp {
  id          Int      @id @default(autoincrement())
  otp         String   @unique
  userId      Int
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  Description String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthToken {
  id          Int      @id @default(autoincrement())
  token       String   @unique
  userId      Int      @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  blacklisted Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  isRevoked Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ======================================
// SHOWCASE
// ======================================

model Showcase {
  id            String         @id @default(uuid())
  userId        Int            @unique
  isVerified    Boolean        @default(false)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  showcaseItems ShowcaseItem[]

  @@index([userId])
}

model ShowcaseItem {
  id                         String             @id @default(uuid())
  title                      String
  description                Json
  imageCount                 Int                @default(0)
  isDraft                    Boolean            @default(false)
  isFromVerifiedCommission   Boolean            @default(false)
  commissionId               String?
  containsMatureContent      Boolean            @default(false)
  contentWarnings            Json               @default("{}")
  likeCount                  Int                @default(0)
  viewCount                  Int                @default(0)
  boostConfig                Json               @default("{}")
  hasTaggedCharacterProfiles Boolean            @default(false)
  taggedCharacterProfiles    Json               @default("[]")
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  isUsingCombinedQuery       Boolean            @default(true)
  document_vectors           Unsupported("tsvector")?

  showcaseId                 String
  showcase                   Showcase           @relation(fields: [showcaseId], references: [id], onDelete: Cascade)

  tags                       Tag[]
  publicViews                PublicViewRecord[]
  bookmarkedBy               Bookmark[]
  showcaseFiles              ShowcaseFile[]
  interactions               UserInteraction[]
  serviceSamples             ServiceSample[]

  @@index([likeCount, createdAt])
  @@index([document_vectors], type: Gin)
  @@index([showcaseId])
  @@index([createdAt(sort: Desc)])
  @@index([isDraft, createdAt(sort: Desc)])
}

model ShowcaseFile {
  id             String       @id @unique @default(uuid())
  showcaseItemId String
  url            String
  type           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  showcaseItem   ShowcaseItem @relation(fields: [showcaseItemId], references: [id], onDelete: Cascade)

  @@index([showcaseItemId, createdAt])
}

model Tag {
  id            String         @id @default(uuid())
  nameTag       String         @unique
  createdAt     DateTime       @default(now())
  showcaseItems ShowcaseItem[]
  services      Service[]
}

// ======================================
// SERVICES (NEW — replaces Folder/Policy/RequestForm)
// ======================================

model Service {
  id                    String             @id @default(uuid())
  userId                Int
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  title                 String
  slug                  String?
  shortDescription      String
  description           Json?
  coverImageUrl         String?

  basePrice             Decimal            @db.Decimal(10, 2)
  currency              String             @default("USD")

  deliveryDaysMin       Int?
  deliveryDaysMax       Int?
  revisionsIncluded     Int                @default(0)

  requestMode           ServiceRequestMode @default(MANUAL_REVIEW)
  status                ServiceStatus      @default(DRAFT)

  slotsEnabled          Boolean            @default(false)
  slotsTotal            Int?
  slotsUsed             Int                @default(0)

  isNSFWAllowed         Boolean            @default(false)
  isCommercialAllowed   Boolean            @default(false)

  canDo                 String?
  cannotDo              String?

  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  addons                ServiceAddon[]
  categories            Tag[]
  questions             ServiceQuestion[]
  samples               ServiceSample[]
  policies              ServicePolicy[]
  orders                Order[]

  @@unique([userId, slug])
  @@index([userId, status])
  @@index([userId, updatedAt(sort: Desc)])
  @@index([userId, status, updatedAt(sort: Desc), id(sort: Desc)], map: "Service_userId_status_updatedAt_id_desc_idx")
  @@index([userId, updatedAt(sort: Desc), id(sort: Desc)], map: "Service_userId_updatedAt_id_desc_idx")
  @@index([status, userId, basePrice, updatedAt(sort: Desc)], map: "Service_status_userId_basePrice_updatedAt_desc_idx")
  @@index([status, createdAt(sort: Desc)])
}

model ServiceAddon {
  id          String   @id @default(uuid())
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("USD")
  isActive    Boolean  @default(true)
  position    Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([serviceId, position])
}

model ServiceQuestion {
  id          String              @id @default(uuid())
  serviceId   String
  service     Service             @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  label       String
  helperText  String?
  type        ServiceQuestionType @default(SHORT_TEXT)
  isRequired  Boolean             @default(false)
  options     Json?
  position    Int                 @default(0)

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([serviceId, position])
}

model ServicePolicy {
  id         String   @id @default(uuid())
  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  title      String
  content    String
  position   Int      @default(0)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([serviceId, position])
}

model ServiceSample {
  id             String       @id @default(uuid())
  serviceId      String
  showcaseItemId String

  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  showcaseItem   ShowcaseItem @relation(fields: [showcaseItemId], references: [id], onDelete: Cascade)

  position       Int          @default(0)
  createdAt      DateTime     @default(now())

  @@unique([serviceId, showcaseItemId])
  @@index([serviceId, position])
  @@index([showcaseItemId])
}

// ======================================
// ORDER / REQUEST FLOW (NEW)
// ======================================

model CustomRequest {
  id              String      @id @default(uuid())
  artistId        Int
  clientId        Int?
  status          OrderStatus @default(PENDING)
  title           String?
  message         String
  attachments     Json?
  budget          Decimal?    @db.Decimal(10, 2)
  currency        String      @default("USD")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  artist          User        @relation("CustomRequestArtist", fields: [artistId], references: [id], onDelete: Cascade)
  client          User?       @relation("CustomRequestClient", fields: [clientId], references: [id], onDelete: SetNull)

  @@index([artistId, status, createdAt(sort: Desc)])
  @@index([clientId, status, createdAt(sort: Desc)])
}

model Order {
  id              String      @id @default(uuid())
  serviceId       String?
  artistId        Int
  clientId        Int?
  source          OrderSource @default(SERVICE)
  status          OrderStatus @default(PENDING)

  titleSnapshot   String?
  briefSnapshot   Json
  priceSnapshot   Decimal     @db.Decimal(10, 2)
  currency        String      @default("USD")

  deliveryDaysMin    Int?
  deliveryDaysMax    Int?
  revisionsIncluded  Int         @default(0)
  revisionsUsed      Int         @default(0)

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  service         Service?       @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  artist          User           @relation("ArtistOrders", fields: [artistId], references: [id], onDelete: Cascade)
  client          User?          @relation("ClientOrders", fields: [clientId], references: [id], onDelete: SetNull)
  payments        Payment[]
  notifications   Notification[] @relation("OrderNotifications")
  conversation    Conversation?  @relation("OrderConversation")
  events          OrderEvent[]

  @@index([artistId, status, createdAt(sort: Desc)])
  @@index([artistId, createdAt(sort: Desc), id(sort: Desc)], map: "Order_artistId_createdAt_id_desc_idx")
  @@index([artistId, updatedAt(sort: Desc)], map: "Order_artistId_updatedAt_desc_idx")
  @@index([artistId, status, updatedAt(sort: Desc)], map: "Order_artistId_status_updatedAt_desc_idx")
  @@index([clientId, status, createdAt(sort: Desc)])
  @@index([serviceId])
}

model Payment {
  id              String          @id @default(uuid())
  orderId         String
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  provider        PaymentProvider @default(PAYPAL)
  status          PaymentStatus   @default(PENDING)

  paypalOrderId   String?         @unique
  paypalCaptureId String?

  amount          Decimal         @db.Decimal(10, 2)
  platformFee     Decimal         @db.Decimal(10, 2) @default(0)
  artistNet       Decimal         @db.Decimal(10, 2) @default(0)
  currency        String          @default("USD")

  paidAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([orderId])
  @@index([paypalOrderId])
  @@index([status, createdAt(sort: Desc)])
  @@map("payments")
}

model Payout {
  id                String       @id @default(uuid())
  artistId          Int
  artist            User         @relation("ArtistPayouts", fields: [artistId], references: [id], onDelete: Cascade)

  amount            Decimal      @db.Decimal(10, 2)
  currency          String       @default("USD")

  status            PayoutStatus @default(PENDING)
  paypalEmail       String

  reviewedAt        DateTime?
  reviewedByAdminId Int?
  reviewNote        String?

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([artistId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("payouts")
}

model OrderEvent {
  id          String         @id @default(uuid())
  orderId     String
  order       Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  type        OrderEventType
  description String
  actorId     Int?
  actor       User?          @relation("OrderEventActor", fields: [actorId], references: [id], onDelete: SetNull)
  metadata    Json?

  createdAt   DateTime       @default(now())

  @@index([orderId, createdAt(sort: Desc)])
  @@map("order_events")
}

// ======================================
// WORKFLOW
// ======================================

model Workflow {
  id        String     @id @default(uuid())
  userId    Int
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  subPhases SubPhase[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("workflows")
  @@index([userId])
}

model SubPhase {
  id         String       @id @default(uuid())
  workflow   Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowId String
  mainPhase  MainPhaseKey
  name       String
  position   Int
  isDefault  Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([workflowId, mainPhase])
  @@map("sub_phases")
}

// ======================================
// DISCOVERY / INTERACTIONS
// ======================================

model UserInteraction {
  id              Int          @id @default(autoincrement())
  userId          Int
  showcaseItemId  String
  interactionType String
  createdAt       DateTime     @default(now())

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  showcaseItem    ShowcaseItem @relation(fields: [showcaseItemId], references: [id], onDelete: Cascade)

  @@unique([userId, showcaseItemId, interactionType])
  @@index([userId, interactionType, createdAt])
}

model Follow {
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())

  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Bookmark {
  id             Int          @id @default(autoincrement())
  userId         Int
  showcaseItemId String
  createdAt      DateTime     @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  showcaseItem   ShowcaseItem @relation(fields: [showcaseItemId], references: [id], onDelete: Cascade)

  @@unique([userId, showcaseItemId])
  @@index([userId, createdAt])
}

// ======================================
// ANTI-BOT / AUDIT
// ======================================

model PublicViewRecord {
  id             Int          @id @default(autoincrement())
  showcaseItemId String
  fingerprint    String
  createdAt      DateTime     @default(now())
  country        String?

  showcaseItem   ShowcaseItem @relation(fields: [showcaseItemId], references: [id], onDelete: Cascade)

  @@index([showcaseItemId, fingerprint, createdAt])
}

model BehavioralLog {
  id             String   @id @default(cuid())
  fingerprint    String
  showcaseItemId String
  timestamp      DateTime @default(now())
  userAgent      String

  @@index([fingerprint, timestamp])
}

model ProfileSearchRecord {
  id             Int      @id @default(autoincrement())
  searchedUserId Int
  searcherUserId Int?
  fingerprint    String
  createdAt      DateTime @default(now())

  searchedUser   User     @relation("ProfileSearches", fields: [searchedUserId], references: [id], onDelete: Cascade)

  @@index([searchedUserId, createdAt])
  @@index([searchedUserId, fingerprint, createdAt])
}

model FingerprintProfile {
  id          String   @id @default(cuid())
  fingerprint String   @unique
  trustScore  Int      @default(100)
  isBlocked   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuthAuditLog {
  id        String   @id @default(cuid())
  userId    Int?
  email     String?
  event     String
  success   Boolean  @default(true)
  message   String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, event, createdAt])
  @@index([event, createdAt])
}

// ======================================
// CHAT & NOTIFICATIONS (preserved — already in production)
// ======================================

model Conversation {
  id        String           @id @default(cuid())
  type      ConversationType @default(DIRECT)
  name      String?
  orderId   String?          @unique
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  order        Order?                   @relation("OrderConversation", fields: [orderId], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id               String    @id @default(cuid())
  conversationId   String
  userId           Int
  joinedAt         DateTime  @default(now())
  leftAt           DateTime?

  unreadCount      Int       @default(0)
  lastMessageAt    DateTime?
  lastMessageText  String?
  lastReadAt       DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, lastMessageAt(sort: Desc)])
  @@index([conversationId])
  @@map("conversation_participants")
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  senderId       Int?
  type           MessageType @default(TEXT)
  content        String?
  fileUrl        String?
  fileName       String?
  isDeleted      Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?        @relation(fields: [senderId], references: [id], onDelete: SetNull)

  notifications Notification[]

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([senderId, createdAt(sort: Desc)])
  @@map("messages")
}

model Notification {
  id        String           @id @default(cuid())
  userId    Int
  type      NotificationType
  title     String?
  body      String?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  messageId      String?
  followerId     Int?
  showcaseItemId String?
  orderId        String?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  order   Order?   @relation("OrderNotifications", fields: [orderId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}
